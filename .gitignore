# Project Data and Results
# Ignore everything in data/ and results/ except structural .gitkeep files
data/*
!data/.gitkeep
!data/README.md
data_old/

results/*
!results/.gitkeep
!results/README.md
results_old/

# Ignore all generated figures except .gitkeep
figs/*
!figs/.gitkeep

